PORT=4000
FRONTEND_URL=http://localhost:3000

# LLM Provider (OpenAI-compatible)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: Enable DALL-E image generation
ENABLE_IMAGE_GENERATION=true

# Optional: News API for fetching AI news (falls back to curated mock data)
NEWS_API_KEY=

# Set to "mock" to force mock generation even with API key
GENERATION_MODE=auto
